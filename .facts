- label: all 31 node sources (after JSDoc strip) are valid pure-JS AsyncFunction bodies (loader in template.ts + every src/nodes/**/*.ts passes AsyncFunction ctor)
  command: bun -e 'const fs=require("fs"),p=require("path"),u=require("url");const d=p.join(p.dirname(u.fileURLToPath(import.meta.url)),"src/nodes");function L(dd,pp=""){const r={};for(const e of fs.readdirSync(dd)){const fp=p.join(dd,e),s=fs.statSync(fp);if(s.isDirectory())Object.assign(r,L(fp,pp+e+":"));else if(e.endsWith(".ts")){let c=fs.readFileSync(fp,"utf8");const ls=c.split("\n");let i=0;while(i<ls.length){const t=ls[i].trim();if(t===""){i++;continue;}if(t.startsWith("/**")){do{i++;}while(i<ls.length&&!ls[i-1].trim().endsWith("*/"));continue;}break;}c=ls.slice(i).join("\n");r[pp+e.slice(0,-3)]=c;}}return r;}const n=L(d);const AF=Object.getPrototypeOf(async function(){}).constructor;let bad=0;for(const s of Object.values(n)){try{new AF("ctx","args",s)}catch(e){console.error("bad node:",e.message);bad++}};if(bad===0){console.log("all 31 node sources valid AsyncFunction");process.exit(0)}process.exit(1)' 
