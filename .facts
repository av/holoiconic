# core

- label: no leftover artifacts in repo root — generated reports, logs, and test outputs go elsewhere
  command: ! ls *.log *.out *.report *.tmp 2>/dev/null
- label: there is a gitignored `.local` folder at repo root for one-off scripts and testing artifacts
  command: grep -q '.local' .gitignore && test -d .local
- label: performance is one of the key considerations when designing new features
  command: true
- label: holoiconic is an agentic runtime where everything exists as quads in a reactive graph backed by Turso
  command: grep -q 'quads' src/db.ts && grep -q '@libsql/client' src/db.ts
- label: the runtime is homoiconic: code, state, context, tools, and the agentic loop are all quads in the same graph
  command: grep -q '"source"' src/template.ts && grep -q "'type', 'Tool'" src/template.ts && grep -q '"agent:loop":' src/template.ts
- label: there is no distinction between system and user data — all quads are equally accessible and mutable
  command: ! grep -q 'protected\|readonly.*quad\|ACL\|permission' src/ctx.ts
- label: breaking sys nodes breaks the runtime — that is by design, the system is fully self-modifiable
  command: grep -q 'ctx\.call =' src/template.ts && ! grep -q 'immutable\|frozen\|Object.freeze' src/ctx.ts
- label: the only runtime dependency is @libsql/client
  command: grep -c '"dependencies"' package.json && jq -r '.dependencies | keys[]' package.json | grep -q '@libsql/client'

# quad

- label: a quad is (s, p, o, g) — subject, predicate, object, graph — all strings
  command: grep -q 's TEXT NOT NULL' src/db.ts && grep -q 'p TEXT NOT NULL' src/db.ts && grep -q 'o TEXT NOT NULL' src/db.ts && grep -q 'g TEXT NOT NULL' src/db.ts
- label: g defaults to '_' when omitted
  command: grep -q "DEFAULT '_'" src/db.ts && grep -q 'g: string = "_"' src/ctx.ts
- label: o (object) holds the value — always a string: a name, source code, JSON, a number-as-string
  command: grep -q 'o TEXT NOT NULL' src/db.ts && grep -q 'o: string' src/ctx.ts
- label: attrs is optional JSON metadata about the quad itself (provenance, timestamp) — never about the subject
  command: grep -q 'attrs TEXT' src/db.ts && grep -q 'attrs.*JSON.parse' src/ctx.ts
- label: embedding is an optional F32_BLOB vector for semantic search
  command: grep -q 'F32_BLOB(1536)' src/db.ts
- label: quads are unique on (s, p, o, g) — asserting an existing quad is a no-op
  command: grep -q 'UNIQUE(s, p, o, g)' src/db.ts && grep -q 'INSERT OR IGNORE' src/ctx.ts
- label: retracting a non-existent quad returns an empty array
  command: grep -q 'return quads' src/ctx.ts
- label: convention: a function is (name, 'source', code) and (name, 'type', 'Function')
  command: grep -q '"source"' src/template.ts && grep -q '"type", "Function"' src/template.ts
- label: convention: value always goes in o, never duplicated in attrs
  command: true

# ctx

- label: ctx is the single context object available everywhere — every node receives it
  command: grep -q 'export function createCtx' src/ctx.ts && grep -q 'new AsyncFunction.*ctx.*args' src/ctx.ts
- label: ctx has 6 primitives: assert, retract, query, call, set, on
  command: grep -A10 'export type Ctx' src/ctx.ts | grep -cE '^\s+(assert|retract|query|call|set|on)\b' | grep -q 6
- label: ctx.assert(s, p, o, g?, embedding?) writes a quad and fires change events — embedding is an optional F32_BLOB vector
  command: bun -e 'const{createDatabase,initSchema}=require("./src/db.ts");const{createCtx}=require("./src/ctx.ts");(async()=>{const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);let fired=false;ctx.on({s:"x"},c=>{if(c.type==="assert")fired=true});const q=await ctx.assert("x","p","v");if(!q.s||!q.p||!q.o)process.exit(1);if(!fired)process.exit(1);console.log("ok")})()'
- label: ctx.retract(s, p, o?, g?) removes matching quads and fires change events — omit o to retract all values for (s, p, g)
  command: bun -e 'const{createDatabase,initSchema}=require("./src/db.ts");const{createCtx}=require("./src/ctx.ts");(async()=>{const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);await ctx.assert("x","p","v1");await ctx.assert("x","p","v2");let fires=0;ctx.on({s:"x"},c=>{if(c.type==="retract")fires++});const r=await ctx.retract("x","p");if(r.length!==2)process.exit(1);if(fires!==2)process.exit(1);console.log("ok")})()'
- label: ctx.query({ s?, p?, o?, g? }) returns Quad[] matching the pattern — omitted fields are wildcards
  command: bun -e 'const{createDatabase,initSchema}=require("./src/db.ts");const{createCtx}=require("./src/ctx.ts");(async()=>{const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);await ctx.assert("a","p","1");await ctx.assert("b","p","2");const all=await ctx.query({p:"p"});if(all.length!==2)process.exit(1);const one=await ctx.query({s:"a",p:"p"});if(one.length!==1||one[0].o!=="1")process.exit(1);console.log("ok")})()'
- label: ctx.call(name, args?) looks up (name, 'source', ?), compiles to AsyncFunction, and runs it
  command: bun -e 'const{createDatabase,initSchema}=require("./src/db.ts");const{createCtx}=require("./src/ctx.ts");(async()=>{const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);await ctx.assert("test:fn","source","return 42");await ctx.assert("test:fn","type","Function");const r=await ctx.call("test:fn");if(r!==42)process.exit(1);console.log("ok")})()'
- label: ctx.on(pattern, callback) watches for quad assert/retract matching pattern, returns an unsubscribe function
  command: bun -e 'const{createDatabase,initSchema}=require("./src/db.ts");const{createCtx}=require("./src/ctx.ts");(async()=>{const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);let count=0;const unsub=ctx.on({s:"x"},()=>count++);await ctx.assert("x","p","v");if(count!==1)process.exit(1);unsub();await ctx.assert("x","p","v2");if(count!==1)process.exit(1);console.log("ok")})()'
- label: ctx.on callback receives { type: 'assert' | 'retract', quad: { id, s, p, o, g, attrs? } }
  command: bun -e 'const{createDatabase,initSchema}=require("./src/db.ts");const{createCtx}=require("./src/ctx.ts");(async()=>{const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);let change;ctx.on({s:"x"},c=>{change=c});await ctx.assert("x","p","v");if(change.type!=="assert")process.exit(1);if(!change.quad.id||!change.quad.s||!change.quad.p||!change.quad.o||!change.quad.g)process.exit(1);console.log("ok")})()'
- label: ctx.self is a getter that returns the name of the currently executing node via AsyncLocalStorage
  command: grep -q 'AsyncLocalStorage' src/ctx.ts && grep -q 'get self' src/ctx.ts
- label: ctx is mutable — nodes can replace any primitive (sys:compiler replaces ctx.call)
  command: grep -q 'ctx\.call =' src/template.ts
- label: everything beyond these 6 primitives — llm, shell, vector, spawn — is implemented as nodes
  command: grep -q '"llm":' src/template.ts && grep -q '"shell":' src/template.ts && grep -q '"vector:search":' src/template.ts && grep -q '"spawn":' src/template.ts
- label: set node delegates to ctx.set — the atomic single-valued predicate primitive
  command: grep -q '"set":' src/template.ts && grep -q 'return ctx.set' src/template.ts
- label: ctx.set(s, p, o, g?) atomically replaces all values for (s, p, g) with a single new value — uses db.batch for atomicity
  command: grep -q 'async set' src/ctx.ts && grep -q 'db.batch' src/ctx.ts

# execution

- label: the platform runtime is Bun
  command: test -f bun.lock
- label: the implementation language is TypeScript
  command: test -f tsconfig.json
- label: one graph node = one callable unit — identified by subject, source in o of a 'source' predicate
  command: grep -q "p = 'source'" src/ctx.ts
- label: each node's source is a function body compiled to AsyncFunction — receives ctx and args
  command: grep -q 'AsyncFunction.*ctx.*args' src/ctx.ts
- nodes have access to all Bun globals (Bun, fetch, Response, console, process)
- nodes can use await import() for dynamic imports of npm packages
- nodes reach other nodes through ctx.call — string-addressed, always resolves current compiled form
- nodes define local helpers and closures but are a single callable unit
- label: compilation is reactive — sys:compiler watches { p: 'source' } and invalidates its cache on change
  command: grep -q "p: 'source'" src/template.ts
- label: all node source strings are syntactically valid AsyncFunction bodies
  command: bun -e 'const AF=Object.getPrototypeOf(async function(){}).constructor;const{nodes}=require("./src/template.ts");for(const[n,s]of Object.entries(nodes)){try{new AF("ctx","args",s)}catch(e){console.error(n,e.message);process.exit(1)}};console.log(Object.keys(nodes).length+" nodes OK")'

# reactivity

- all mutations through ctx.assert/ctx.retract emit events to ctx.on subscribers
- subscriptions are in-process and ephemeral — nodes register them on start, they vanish on process exit
- on restart, nodes re-run and re-register their subscriptions naturally
- ctx.on takes a pattern { s?, p?, o?, g? } — omitted fields are wildcards
- ctx.on returns an unsubscribe function
- reactive callbacks fire only on actual changes — duplicate asserts and missing retracts are no-ops
- label: lifecycle events are quads, not a separate mechanism — supervisor asserts (name, 'lifecycle', 'cleanup')
  command: grep -q "'lifecycle'" src/template.ts
- nodes can watch their own lifecycle via ctx.on({ s: ctx.self, p: 'lifecycle', o: 'cleanup' }, callback) — supported but not currently used by any built-in node

# spawn

- label: spawn is a node, not a kernel primitive — invoked via ctx.call('spawn', { node, args? })
  command: grep -q '"spawn":' src/template.ts
- label: spawn uses AbortController internally to manage the lifecycle of long-lived nodes
  command: grep -q 'AbortController' src/template.ts
- label: spawned nodes receive args.signal (AbortSignal) for cooperative cancellation
  command: grep -q 'args.signal' src/template.ts
- when a spawned node's source changes, sys:supervisor detects it, asserts (name, 'lifecycle', 'cleanup'), aborts, and re-runs the node
- multiple cleanup handlers can be registered — same mechanism as graph reactivity
- label: sys:supervisor retries crashed nodes with exponential backoff — max 3 retries, delays 500/1000/2000ms — retry count resets on manual source change
  command: grep -q 'Math.pow(2' src/template.ts && grep -q '500' src/template.ts

# bootstrap

- label: the kernel is ~30 lines of TypeScript — pure plumbing, no policy
  command: test $(grep -c '' src/boot.ts) -le 50
- label: kernel connects to Turso, creates ctx with the 6 primitives, and calls ctx.call('main')
  command: grep -q 'createDatabase' src/boot.ts && grep -q 'createCtx' src/boot.ts && grep -q 'call.*main' src/boot.ts
- label: the kernel's ctx.call compiles from scratch on every call — no cache, no reactivity
  command: grep -q 'no cache' src/ctx.ts
- the kernel wires assert/retract to emit events through ctx.on automatically
- label: if the graph is empty on boot, the kernel seeds it from a template
  command: grep -q 'length === 0' src/boot.ts && grep -q 'seedTemplate' src/boot.ts
- label: the template seeds 28 nodes: sys:compiler, sys:supervisor, main, spawn, shell, llm, agent:tools, agent:loop, api:server, web:ui, repl, set, snapshots, embed, vector:search, graph introspection, versioning, cron, and metrics
  command: test $(grep -c '^  "' src/template.ts) -ge 28
- label: main calls sys:compiler first — which replaces ctx.call with a cached, reactively-invalidated version
  command: grep -q 'sys:compiler' src/template.ts
- main then calls spawn for sys:supervisor and the application
- before sys:compiler runs, compilation is cold — after, it is live and reactive
- all sys nodes are rewritable like any other node
- label: the project builds and all integration tests pass
  command: bun run src/test-boot.ts 2>&1 | grep -q 'passed, 0 failed'

# interfaces

- label: holoiconic exposes a REPL for interactive use
  command: grep -q '"repl":' src/template.ts
- label: holoiconic exposes a WebUI
  command: grep -q '"web:ui":' src/template.ts
- label: holoiconic exposes an OpenAI-compatible API
  command: grep -q '/v1/chat/completions' src/template.ts && grep -q '/v1/models' src/template.ts

# repl

- primary input is natural language → agent:loop; dot-commands are escape hatches
- repl starts a new session by default — session ID is repl:<timestamp>, conversation history stored as quads
- repl is built on pi-mono — TUI rendering, streaming, markdown, syntax highlighting, and tool-call display are framework-provided
- LLM responses stream by default
- .query queries quads by JSON pattern
- .assert inserts a quad (s p o [--g graph])
- .retract removes a quad (s p o [--g graph])
- .call invokes a node by name with optional JSON args
- .nodes lists all Function-typed nodes
- .source shows a node's source code
- .edit opens inline multi-line editing of a node's source — blank line terminates
- .create creates a new node with inline multi-line source — blank line terminates
- .spawn starts a long-lived node via sys:supervisor
- .session shows the current session ID
- .sessions lists all sessions stored in the graph
- .resume loads a previous session's conversation history from the graph
- .export exports the graph as a JSON snapshot, optionally to a file path
- .import imports quads from a JSON snapshot file
- .deps shows a node's call dependencies and dependents
- .inspect shows comprehensive node info — types, source, schema, deps
- .versions lists saved source versions for a node
- .restore restores a node to a previous version by seq number
- .cron starts a node on a periodic timer (interval in ms)
- .crons lists all cron jobs and their status
- .metrics shows per-node call count, duration, and error statistics
- .eval runs arbitrary AsyncFunction code with ctx in scope

# agentic

- label: there is no separate Agent class — the agentic loop is nodes in the graph like everything else
  command: ! grep -rq 'class Agent' src/
- the loop, tool dispatch, and LLM calls are all graph-resident nodes invocable and modifiable through ctx
- the agent can rewrite any part of itself — its loop, its tools, its LLM parameters — by mutating quads
- label: the agent's context window is written to the same graph as everything else
  command: grep -q 'ctx.assert.*message' src/template.ts
- because everything is in the graph, arbitrary external harnesses can drive execution too
- label: agent:tools registers 18 tools for the LLM agent, each stored as a Tool-typed quad with an input_schema
  command: test $(grep -c "'type', 'Tool'" src/template.ts) -eq 18
- label: embed generates vector embeddings via OpenAI API (text-embedding-3-small) with deterministic stub fallback when no API key is set
  command: grep -q 'text-embedding-3-small' src/template.ts
- label: vector:search performs semantic search using cosine similarity over stored embeddings, with brute-force fallback
  command: grep -q 'cosineSim\|cosine' src/template.ts
- label: graph introspection nodes (graph:describe, graph:subjects, graph:deps, inspect) provide structural analysis of the graph and dependency tracking
  command: grep -q '"graph:describe":' src/template.ts && grep -q '"graph:deps":' src/template.ts && grep -q '"inspect":' src/template.ts
- label: agent:loop is a multi-turn loop — call LLM, run any tool calls, feed results back, repeat (max 20 turns)
  command: grep -q 'maxIterations.*20' src/template.ts
- label: all conversation messages are stored as quads in the session graph — user, assistant, and tool results
  command: grep -q 'seq: seq++, msg: userMsg' src/template.ts && grep -q 'seq: seq++, msg: assistantMsg' src/template.ts && grep -q 'seq: seq++, msg: toolResultMsg' src/template.ts
- label: tool names use underscores in LLM schemas, colons in the graph — dispatch translates automatically
  command: grep -q 'replace(/_/g' src/template.ts
- label: agent:loop gives the LLM a system prompt explaining the runtime — quads, reactivity, available tools
  command: grep -q 'systemPrompt' src/template.ts && grep -q 'reactive graph' src/template.ts
- label: the llm node calls the Anthropic Messages API via fetch — streaming by default
  command: grep -q 'api.anthropic.com/v1/messages' src/template.ts && ! grep -q 'pi-ai\|@anthropic-ai/sdk' src/template.ts
- label: the llm node defaults to claude-sonnet-4-20250514 and returns a deterministic stub when no ANTHROPIC_API_KEY is set
  command: grep -q 'claude-sonnet-4-20250514' src/template.ts && grep -q 'ANTHROPIC_API_KEY' src/template.ts
- label: embed persists computed embeddings in the graph (graph='embeddings') so vector:search can reuse them without recomputing
  command: grep -q "'embeddings'" src/template.ts
- label: agent:loop returns the final response plus a log of every tool call made during the turn
  command: grep -q 'allToolCalls' src/template.ts

# providers

- first-class provider is OpenAI-compatible — Anthropic is one of many, not primary
- llm and embed nodes use @mariozechner/pi-ai — no raw fetch to any provider
- pi-ai covers OpenAI, Anthropic, Google, Mistral, Groq, Bedrock, Ollama, and custom endpoints
- auth via pi-ai OAuth — Claude Pro/Max, GitHub Copilot, Gemini CLI all supported
- tool schemas use TypeBox (re-exported from pi-ai)
- agent:loop uses pi-ai stream/complete, stays graph-resident

# versioning
- label: sys:compiler auto-saves the old source as a version via version:save whenever a source quad is retracted
  command: grep -q 'version:save' src/template.ts
- label: version:list returns all saved versions for a node with seq numbers and timestamps
  command: grep -q '"version:list":' src/template.ts
- label: version:restore restores a node to a specific version by seq number — retracts current source and asserts the old one, triggering reactive recompilation
  command: grep -q '"version:restore":' src/template.ts

# observability
- label: sys:compiler automatically records call count, duration, and errors for every ctx.call except calls to metrics nodes
  command: grep -q "'metrics'" src/template.ts
- label: metrics:report generates a formatted table of per-node call statistics sorted by call count
  command: grep -q '"metrics:report":' src/template.ts

# scheduling
- label: cron runs a node on setInterval, registers job metadata as CronJob-typed quads, supports AbortSignal for cleanup
  command: grep -q '"cron":' src/template.ts && grep -q 'setInterval' src/template.ts

# snapshots
- snapshot:backup copies the local SQLite file via Bun.write — raw file copy, not SQLite backup API
- snapshot:backup defaults to holoiconic.db as source, generates a timestamped destination — both overridable via args
- snapshot:backup throws if the source file doesn't exist — only works with local SQLite, not remote Turso
- snapshot:export serializes all quads as JSON with s, p, o, g, and attrs fields — embedding vectors are stripped
- snapshot:export returns a JSON string by default, or writes to a file when args.path is provided
- snapshot:import accepts quads from a file path (args.path) or inline JSON string (args.data)
- snapshot:import asserts each quad via ctx.assert — duplicates are no-ops, reactive events fire normally
- snapshot:import skips quads missing s, p, or o fields and reports the skip count
- Turso Cloud branching and point-in-time restore are platform-level — holoiconic does not implement or wrap them
