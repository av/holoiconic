# holoiconic .env.example
# Copy this file to .env (which is gitignored) and customize, or export vars in shell.
# All vars are optional; without LLM key+base the runtime falls back to the built-in mock:llm.

# =============================================================================
# Custom OpenAI-compatible provider (makes launch against Groq, Ollama, vLLM,
# llama.cpp, Fireworks, Together.ai, local servers, etc. trivial)
# =============================================================================
# PERSISTENT CONFIG FILE (recommended for day-to-day use):
#   cp .holoiconic.json.example .holoiconic.json
#   # edit the copy (supports {provider:{baseUrl,apiKey,model}} or flat); then
#   # bun start  — loaded automatically, survives restarts, gitignored.
#   # See .holoiconic.json.example for 3 documented examples (Groq/Ollama/OpenRouter).
#   # Override search (cwd + ~) with exact path via env/CLI:
#   #   HOLOICONIC_CONFIG=/abs/path/to/my-config.json bun start
#   #   # (HOLOICONIC_CONFIG_PATH also accepted; or --config PATH on CLI)
#
# Use OPENAI_BASE_URL (preferred) or OPENAI_API_BASE (alias) to point at any
# OpenAI-compat /v1 endpoint. The llm, agent:loop, embed, and api:server nodes
# will target it directly (synthetic model path; dummy 'sk-local' key auto-used
# if no real key provided — works for auth-less local servers).
OPENAI_BASE_URL=https://api.groq.com/openai
# OPENAI_API_BASE=https://api.groq.com/openai   # alias also supported everywhere

# API key for the custom endpoint (or any non-empty value for local/no-auth).
# Falls back to 'sk-local' automatically when OPENAI_BASE_URL present.
OPENAI_API_KEY=gsk_your_groq_or_other_key_here

# Model name selection (checked in this order; works for both completions + embeddings)
HOLOICONIC_MODEL=llama-3.1-70b-versatile
# OPENAI_MODEL=llama-3.1-70b-versatile   # alias
# MODEL=...                              # fallback alias

# =============================================================================
# Server ports (api:server on HOLO_API_PORT, web:ui on HOLO_WEB_PORT)
# Can also be set via CLI --api-port / --web-port
HOLO_API_PORT=3001
HOLO_WEB_PORT=3002

# =============================================================================
# Other providers / legacy
ANTHROPIC_API_KEY=sk-ant-api03_your_anthropic_key_here

# =============================================================================
# Database (local file holoiconic.db is default; set these for Turso Cloud)
TURSO_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# =============================================================================
# Launch examples for custom OpenAI-compatible (all equivalent)
# ----------------------------------------------------------------------------
# 1. Pure env (easiest for scripts/CI):
#    OPENAI_BASE_URL=https://api.groq.com/openai \
#    OPENAI_API_KEY=gsk_... \
#    HOLOICONIC_MODEL=llama-3.1-8b-instant \
#    bun start
#
# 2. CLI flags (explicit, works with bun start via -- separator):
#    bun start -- --openai-base-url=https://api.groq.com/openai \
#                     --openai-api-key=gsk_... \
#                     --model=llama-3.1-70b-versatile \
#                     --api-port=3001
#    # or directly: bun src/boot.ts --openai-base-url=... -b ... --help
#
# 3. REPL interactive override (per-session, after boot; overrides globals):
#    holo> .provider set --base https://api.groq.com/openai --key gsk_... --model llama-3.1-70b
#    holo> .provider show
#    holo> chat tell me a joke
#    holo> .provider clear
#
# 4. Per-request (for calls hitting the OpenAI-compat API at :3001 or WebUI):
#    curl -X POST http://localhost:3001/v1/chat/completions \
#      -H "Content-Type: application/json" \
#      -H "x-openai-base-url: https://api.groq.com/openai" \
#      -H "x-openai-api-key: gsk_..." \
#      -d '{"model":"llama-3.1-70b-versatile","messages":[{"role":"user","content":"hi"}]}'
#    # Also supported in body: {"baseUrl": "...", "apiKey": "...", "model": "..."}
#    # or Authorization: Bearer <key> header (key extracted, base from x- or body)
#
# 5. --help shows all CLI options:
#    bun src/boot.ts --help
#    # (or bun start -- --help)
#
# Precedence (highest wins): CLI flags > config file (.holoiconic.json) > process.env / Bun.env > node defaults
# (mock:llm only when neither key nor baseUrl present).
# See .holoiconic.json.example + README "Using custom..." section for the cp command and all 6 methods.
#
# See CLAUDE.md "Environment variables" section and README for full details.
# The runtime (main, llm, agent:loop, embed, api/server, repl) all respect these uniformly.
