# core

- label: no leftover artifacts in repo root — generated reports, logs, and test outputs go elsewhere
  command: ! ls *.log *.out *.report *.tmp 2>/dev/null
- label: there is a gitignored `.local` folder at repo root for one-off scripts and testing artifacts
  command: grep -q '.local' .gitignore && test -d .local
- label: facts must not hardcode counts of nodes, tools, or other enumerables — counts drift silently and create false failures
  command: true
- label: performance is one of the key considerations when designing new features
  command: true
- label: facts check must run in ~10s
  command: timeout 5s /tmp/facts check --tags core > /dev/null 2>&1
- label: holoiconic is an agentic runtime where everything exists as quads in a reactive graph backed by Turso
  command: grep -q 'quads' src/db.ts && grep -q '@libsql/client' src/db.ts
- label: the runtime is homoiconic: code, state, context, tools, and the agentic loop are all quads in the same graph
  command: grep -q 'quads' src/db.ts && test -f src/nodes/agent/loop.ts && test -f src/nodes/llm.ts && grep -q 'ctx.call' src/nodes/agent/loop.ts
- label: there is no distinction between system and user data — all quads are equally accessible and mutable
  command: ! grep -q 'protected\|readonly.*quad\|ACL\|permission' src/ctx.ts
- label: breaking sys nodes breaks the runtime — that is by design, the system is fully self-modifiable
  command: test -f src/nodes/sys/compiler.ts && grep -q 'ctx\.call =' src/nodes/sys/compiler.ts && ! grep -q 'immutable\|frozen\|Object.freeze' src/ctx.ts
- label: runtime dependencies include libsql/client, mariozechner/pi-ai, and mariozechner/pi-tui
  command: jq -r '.dependencies | keys[]' package.json | grep -q '@libsql/client' && jq -r '.dependencies | keys[]' package.json | grep -q '@mariozechner/pi-ai' && jq -r '.dependencies | keys[]' package.json | grep -q '@mariozechner/pi-tui'

# quad

- label: a quad is (subject, predicate, object, graph) — all strings
  command: grep -q 'subject TEXT NOT NULL' src/db.ts && grep -q 'predicate TEXT NOT NULL' src/db.ts && grep -q 'object TEXT NOT NULL' src/db.ts && grep -q 'graph TEXT NOT NULL' src/db.ts
- label: graph defaults to '_' when omitted
  command: grep -q "DEFAULT '_'" src/db.ts && grep -q 'graph: string = "_"' src/ctx.ts
- label: object holds the value — always a string: a name, source code, JSON, a number-as-string
  command: grep -q 'object TEXT NOT NULL' src/db.ts && grep -q 'object: string' src/ctx.ts
- label: attrs is optional JSON metadata about the quad itself (provenance, timestamp) — never about the subject
  command: grep -q 'attrs TEXT' src/db.ts && grep -q 'attrs.*JSON.parse' src/ctx.ts
- label: embedding is an optional F32_BLOB vector for semantic search
  command: grep -q 'F32_BLOB(1536)' src/db.ts
- label: quads are unique on (subject, predicate, object, graph) — inserting an existing quad is a no-op
  command: grep -q 'UNIQUE(subject, predicate, object, graph)' src/db.ts && grep -q 'INSERT OR IGNORE' src/ctx.ts
- label: removing a non-existent quad returns an empty array
  command: bun -e 'const{createDatabase,initSchema}=require("./src/db.ts");const{createCtx}=require("./src/ctx.ts");(async()=>{const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);const r=await ctx.remove("nonexistent","nope","nothing");if(!Array.isArray(r)||r.length!==0)process.exit(1);console.log("ok")})()'
- label: convention: a function is (name, 'source', code) and (name, 'type', 'Function')
  command: grep -q '"source"' src/template.ts && grep -q '"type", "Function"' src/template.ts
- label: convention: value always goes in object, never duplicated in attrs
  command: true

# ctx

- label: ctx is the single context object available everywhere — every node receives it
  command: grep -q 'export function createCtx' src/ctx.ts && grep -q 'new AsyncFunction.*ctx.*args' src/ctx.ts
- label: ctx has 6 primitives: insert, remove, query, call, set, on
  command: grep -A10 'export type Ctx' src/ctx.ts | grep -cE '^\s+(insert|remove|query|call|set|on)\b' | grep -q 6
- label: ctx.insert(subject, predicate, object, graph?, embedding?) writes a quad and fires change events — embedding is an optional F32_BLOB vector
  command: bun -e 'const{createDatabase,initSchema}=require("./src/db.ts");const{createCtx}=require("./src/ctx.ts");(async()=>{const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);let fired=false;ctx.on({subject:"x"},c=>{if(c.type==="insert")fired=true});const q=await ctx.insert("x","p","v");if(!q.subject||!q.predicate||!q.object)process.exit(1);if(!fired)process.exit(1);console.log("ok")})()'
- label: ctx.remove(subject, predicate, object?, graph?) removes matching quads and fires change events — omit object to remove all values for (subject, predicate, graph)
  command: bun -e 'const{createDatabase,initSchema}=require("./src/db.ts");const{createCtx}=require("./src/ctx.ts");(async()=>{const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);await ctx.insert("x","p","v1");await ctx.insert("x","p","v2");let fires=0;ctx.on({subject:"x"},c=>{if(c.type==="remove")fires++});const r=await ctx.remove("x","p");if(r.length!==2)process.exit(1);if(fires!==2)process.exit(1);console.log("ok")})()'
- label: ctx.query({ subject?, predicate?, object?, graph? }) returns Quad[] matching the pattern — omitted fields are wildcards
  command: bun -e 'const{createDatabase,initSchema}=require("./src/db.ts");const{createCtx}=require("./src/ctx.ts");(async()=>{const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);await ctx.insert("a","p","1");await ctx.insert("b","p","2");const all=await ctx.query({predicate:"p"});if(all.length!==2)process.exit(1);const one=await ctx.query({subject:"a",predicate:"p"});if(one.length!==1||one[0].object!=="1")process.exit(1);console.log("ok")})()'
- label: ctx.call(name, args?) looks up (name, 'source', ?), compiles to AsyncFunction, and runs it
  command: bun -e 'const{createDatabase,initSchema}=require("./src/db.ts");const{createCtx}=require("./src/ctx.ts");(async()=>{const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);await ctx.insert("test:fn","source","return 42");await ctx.insert("test:fn","type","Function");const r=await ctx.call("test:fn");if(r!==42)process.exit(1);console.log("ok")})()'
- label: ctx.on(pattern, callback) watches for quad insert/remove matching pattern, returns an unsubscribe function
  command: bun -e 'const{createDatabase,initSchema}=require("./src/db.ts");const{createCtx}=require("./src/ctx.ts");(async()=>{const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);let count=0;const unsub=ctx.on({subject:"x"},()=>count++);await ctx.insert("x","p","v");if(count!==1)process.exit(1);unsub();await ctx.insert("x","p","v2");if(count!==1)process.exit(1);console.log("ok")})()'
- label: ctx.on callback receives { type: 'insert' | 'remove', quad: { id, subject, predicate, object, graph, attrs? } }
  command: bun -e 'const{createDatabase,initSchema}=require("./src/db.ts");const{createCtx}=require("./src/ctx.ts");(async()=>{const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);let change;ctx.on({subject:"x"},c=>{change=c});await ctx.insert("x","p","v");if(change.type!=="insert")process.exit(1);if(!change.quad.id||!change.quad.subject||!change.quad.predicate||!change.quad.object||!change.quad.graph)process.exit(1);console.log("ok")})()'
- label: ctx.self is a getter that returns the name of the currently executing node via AsyncLocalStorage
  command: grep -q 'AsyncLocalStorage' src/ctx.ts && grep -q 'get self' src/ctx.ts
- label: ctx is mutable — nodes can replace any primitive (sys:compiler replaces ctx.call)
  command: test -f src/nodes/sys/compiler.ts && grep -q 'ctx\.call =' src/nodes/sys/compiler.ts
- label: everything beyond these 6 primitives — llm, shell, vector, spawn — is implemented as nodes
  command: test -f src/nodes/llm.ts && test -f src/nodes/shell.ts && test -f src/nodes/vector/search.ts && test -f src/nodes/spawn.ts
- label: set node delegates to ctx.set — the atomic single-valued predicate primitive
  command: test -f src/nodes/set.ts && grep -q 'return ctx.set' src/nodes/set.ts
- label: ctx.set(subject, predicate, object, graph?) atomically replaces all values for (subject, predicate, graph) with a single new value — uses db.batch for atomicity
  command: grep -q 'async set' src/ctx.ts && grep -q 'db.batch' src/ctx.ts

# execution

- label: the platform runtime is Bun
  command: test -f bun.lock
- label: the implementation language is TypeScript
  command: test -f tsconfig.json
- label: one graph node = one callable unit — identified by subject, source in object of a 'source' predicate
  command: grep -q "predicate = 'source'" src/ctx.ts
- label: each node's source is a function body compiled to AsyncFunction — receives ctx and args
  command: grep -q 'AsyncFunction.*ctx.*args' src/ctx.ts
- label: nodes have access to all Bun globals (Bun, fetch, Response, console, process)
- label: nodes can use await import() for dynamic imports of npm packages
  command: bun -e 'const{createDatabase,initSchema}=require("./src/db.ts");const{createCtx}=require("./src/ctx.ts");(async()=>{const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);await ctx.insert("test:import","source","const m = await import(\"node:path\"); return m.sep");await ctx.insert("test:import","type","Function");const r=await ctx.call("test:import");if(typeof r!=="string")process.exit(1);console.log("ok")})()'
- label: nodes reach other nodes through ctx.call — string-addressed, always resolves current compiled form
  command: bun -e 'const{createDatabase,initSchema}=require("./src/db.ts");const{createCtx}=require("./src/ctx.ts");(async()=>{const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);await ctx.insert("a:node","source","return 42");await ctx.insert("a:node","type","Function");await ctx.insert("b:node","source","return await ctx.call(\"a:node\")");await ctx.insert("b:node","type","Function");const r=await ctx.call("b:node");if(r!==42)process.exit(1);console.log("ok")})()'
- label: nodes define local helpers and closures but are a single callable unit
  command: bun -e 'const{createDatabase,initSchema}=require("./src/db.ts");const{createCtx}=require("./src/ctx.ts");(async()=>{const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);await ctx.insert("t:fn","source","function helper(x){return x*2} const y=helper(21); return y");await ctx.insert("t:fn","type","Function");const r=await ctx.call("t:fn");if(r!==42)process.exit(1);console.log("ok")})()'
- label: compilation is reactive — sys:compiler watches { predicate: 'source' } and invalidates its cache on change
  command: test -f src/nodes/sys/compiler.ts && grep -q "ctx.on.*predicate: 'source'" src/nodes/sys/compiler.ts && grep -q 'cache.delete' src/nodes/sys/compiler.ts
- label: all node source strings are syntactically valid AsyncFunction bodies
  command: bun -e 'const AF=Object.getPrototypeOf(async function(){}).constructor;const{nodes}=require("./src/template.ts");for(const[n,s]of Object.entries(nodes)){try{new AF("ctx","args",s)}catch(e){console.error(n,e.message);process.exit(1)}};console.log(Object.keys(nodes).length+" nodes OK")'

# reactivity

- label: all mutations through ctx.insert/ctx.remove emit events to ctx.on subscribers
  command: grep -q 'fire({ type: "insert"' src/ctx.ts && grep -q 'fire({ type: "remove"' src/ctx.ts
- label: subscriptions are in-process and ephemeral — nodes register them on start, they vanish on process exit
- label: on restart, nodes re-run and re-register their subscriptions naturally
  command: test -f src/nodes/sys/compiler.ts && grep -q 'ctx.on.*source' src/nodes/sys/compiler.ts && test -f src/nodes/sys/supervisor.ts && grep -q 'ctx.on.*type.*Spawned' src/nodes/sys/supervisor.ts
- label: ctx.on takes a pattern { subject?, predicate?, object?, graph? } — omitted fields are wildcards
  command: grep -q 'on(pattern: Pattern' src/ctx.ts && grep -q 'subject?: string' src/ctx.ts && grep -q 'predicate?: string' src/ctx.ts
- label: ctx.on returns an unsubscribe function
  command: grep -q 'on(pattern: Pattern, callback: Subscriber): () => void' src/ctx.ts
- label: reactive callbacks fire only on actual changes — duplicate inserts and missing removes are no-ops
  command: bun -e 'const{createDatabase,initSchema}=require("./src/db.ts");const{createCtx}=require("./src/ctx.ts");(async()=>{const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);let fires=0;ctx.on({subject:"x"},()=>fires++);await ctx.insert("x","p","v");await ctx.insert("x","p","v");const r=await ctx.remove("x","p","missing");if(fires!==1)process.exit(1);if(r.length!==0)process.exit(1);console.log("ok")})()'
- label: lifecycle events are quads, not a separate mechanism — supervisor inserts (name, 'lifecycle', 'cleanup')
  command: test -f src/nodes/sys/supervisor.ts && grep -q "ctx.insert(name, 'lifecycle', 'cleanup')" src/nodes/sys/supervisor.ts
- label: nodes can watch their own lifecycle via ctx.on({ subject: ctx.self, predicate: 'lifecycle', object: 'cleanup' }, callback) — supported but not currently used by any built-in node
  command: test -f src/nodes/sys/supervisor.ts && grep -q 'lifecycle' src/nodes/sys/supervisor.ts && grep -q 'cleanup' src/nodes/sys/supervisor.ts
- label: ctx.on reactivity uses a 16-mask quadToKeys generator (all combinations of concrete/wildcard for s/p/o/g) + snapshot = bucket.slice() before invoking subscribers to safely support mutation during callbacks
  command: grep -q 'for (const key of quadToKeys' src/ctx.ts && grep -q 'const snapshot = bucket.slice' src/ctx.ts && grep -q 'quadToKeys' src/ctx.ts

# spawn

- label: spawn is a node, not a kernel primitive — invoked via ctx.call('spawn', { node, args? })
  command: test -f src/nodes/spawn.ts && grep -q 'spawn' src/nodes/spawn.ts
- label: spawn uses AbortController internally to manage the lifecycle of long-lived nodes
  command: test -f src/nodes/spawn.ts && grep -q 'AbortController' src/nodes/spawn.ts && test -f src/nodes/sys/supervisor.ts && grep -q 'AbortController' src/nodes/sys/supervisor.ts
- label: spawned nodes receive args.signal (AbortSignal) for cooperative cancellation
  command: test -f src/nodes/spawn.ts && grep -q 'signal' src/nodes/spawn.ts
- label: when a spawned node's source changes, sys:supervisor detects it, inserts (name, 'lifecycle', 'cleanup'), aborts, and re-runs the node
  command: test -f src/nodes/sys/supervisor.ts && grep -q "ctx.on.*predicate: 'source'" src/nodes/sys/supervisor.ts && grep -q "ctx.insert(name, 'lifecycle', 'cleanup')" src/nodes/sys/supervisor.ts && grep -q 'ac.abort()' src/nodes/sys/supervisor.ts
- label: multiple cleanup handlers can be registered — same mechanism as graph reactivity
  command: bun -e 'const{createDatabase,initSchema}=require("./src/db.ts");const{createCtx}=require("./src/ctx.ts");(async()=>{const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);let a=0,b=0;ctx.on({subject:"n",predicate:"lifecycle",object:"cleanup"},()=>a++);ctx.on({subject:"n",predicate:"lifecycle",object:"cleanup"},()=>b++);await ctx.insert("n","lifecycle","cleanup");if(a!==1||b!==1)process.exit(1);console.log("ok")})()'
- label: sys:supervisor retries crashed nodes with exponential backoff — max 3 retries, delays 500/1000/2000ms — retry count resets on manual source change
  command: test -f src/nodes/sys/supervisor.ts && grep -q 'MAX_RETRIES = 3' src/nodes/sys/supervisor.ts && grep -q 'Math.pow(2' src/nodes/sys/supervisor.ts && grep -q 'retryCounts.set(name, 0)' src/nodes/sys/supervisor.ts

# bootstrap

- label: the kernel (src/boot.ts) is a small file (~120 lines) of TypeScript — pure plumbing, no policy. All behavior defined in graph-resident nodes seeded from src/nodes/
  command: test $(grep -c "" src/boot.ts) -le 120
- label: kernel connects to Turso, creates ctx with the 6 primitives, and calls ctx.call('main')
  command: grep -q 'createDatabase' src/boot.ts && grep -q 'createCtx' src/boot.ts && grep -q 'call.*main' src/boot.ts
- label: the kernel's ctx.call compiles from scratch on every call — no cache, no reactivity
  command: grep -A12 'async call' src/ctx.ts && ! grep -A12 'async call' src/ctx.ts | grep -q 'cache\|Map'
- label: the kernel wires insert/remove to emit events through ctx.on automatically
  command: grep -q 'function fire' src/ctx.ts && grep -q 'fire({ type: "insert"' src/ctx.ts && grep -q 'fire({ type: "remove"' src/ctx.ts
- label: if the graph is empty on boot, the kernel seeds it from a template
  command: grep -q 'length === 0' src/boot.ts && grep -q 'seedTemplate' src/boot.ts
- label: the template (via loadNodes + seedTemplate) seeds all nodes — sys, spawn, shell, llm, agent, api, web, repl, set, mock, snapshots, embed, vector, graph introspection, versioning, cron, and metrics — by walking src/nodes/ tree and inserting (name, 'source', stripped) + (name, 'type', 'Function')
  command: grep -q 'seedTemplate' src/template.ts && grep -q 'loadNodes' src/template.ts && test -f src/nodes/sys/compiler.ts && test -f src/nodes/main.ts && test -f src/nodes/repl.ts && test -f src/nodes/cron/stop.ts && test -f src/nodes/agent/loop.ts && test -f src/nodes/snapshot/export.ts
- label: main calls sys:compiler first — which replaces ctx.call with a cached, reactively-invalidated version
  command: test -f src/nodes/main.ts && grep -q 'sys:compiler' src/nodes/main.ts
- label: main then calls spawn for sys:supervisor and the application
  command: test -f src/nodes/main.ts && grep -q "spawn.*node.*sys:supervisor" src/nodes/main.ts && grep -q "spawn.*node.*api:server" src/nodes/main.ts
- label: before sys:compiler runs, compilation is cold — after, it is live and reactive
  command: grep -A12 'async call' src/ctx.ts | grep -q 'new AsyncFunction' && ! grep -A12 'async call' src/ctx.ts | grep -q 'cache\|Map' && test -f src/nodes/sys/compiler.ts && grep -q 'cachedCall' src/nodes/sys/compiler.ts
- label: all sys nodes are rewritable like any other node
  command: bun -e 'const{createDatabase,initSchema}=require("./src/db.ts");const{createCtx}=require("./src/ctx.ts");(async()=>{const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);await ctx.insert("sys:compiler","source","return 1");const r=await ctx.remove("sys:compiler","source","return 1");if(r.length!==1)process.exit(1);await ctx.insert("sys:compiler","source","return 2");const q=await ctx.query({subject:"sys:compiler",predicate:"source"});if(q[0].object!=="return 2")process.exit(1);console.log("ok")})()'
- label: the project builds and all integration tests pass
- label: main node uses waitForPortQuad polling (query for readiness quads like 'web:ui'/'port' or 'mock:llm'/'url' with 50ms steps, max 2s) instead of fixed sleeps for deterministic boot under variable startup times
  command: grep -q 'waitForPortQuad' src/nodes/main.ts && grep -q 'while (Date.now() - start < maxMs)' src/nodes/main.ts

## loader
- label: src/template.ts implements loadNodes() — recursive readdirSync walker that turns src/nodes/<dir>/<file>.ts into namespaced node names (e.g. sys/compiler.ts -> 'sys:compiler', cron/list.ts -> 'cron:list') and strips leading JSDoc + blanks before seeding
  command: grep -q 'function loadNodes' src/template.ts && grep -q 'prefix + entry + ":"' src/template.ts && grep -q 'entry.slice(0, -3)' src/template.ts

# interfaces

- label: holoiconic exposes a REPL for interactive use
  command: test -f src/nodes/repl.ts && grep -q 'createInterface' src/nodes/repl.ts && grep -q 'readline' src/nodes/repl.ts
- label: holoiconic exposes a WebUI — dual-panel layout with chat on the left and graph explorer on the right
  command: test -f src/nodes/web/ui.ts && grep -q 'chat-panel' src/nodes/web/ui.ts && grep -q 'graph-panel' src/nodes/web/ui.ts
- label: web:ui graph panel supports node search/filter, inline source editing with save, and type badges (Function/Tool/Spawned)
  command: test -f src/nodes/web/ui.ts && grep -q 'node-search' src/nodes/web/ui.ts && grep -q 'save-btn' src/nodes/web/ui.ts && grep -q 'badge-tool' src/nodes/web/ui.ts
- label: holoiconic exposes an OpenAI-compatible API
  command: test -f src/nodes/api/server.ts && grep -q '/v1/chat/completions' src/nodes/api/server.ts && grep -q '/v1/models' src/nodes/api/server.ts && grep -q '/v1/embeddings' src/nodes/api/server.ts
- label: api:server exposes a /health endpoint returning { status: 'ok' }
  command: test -f src/nodes/api/server.ts && grep -q "'/health'" src/nodes/api/server.ts && grep -q "status: 'ok'" src/nodes/api/server.ts
- label: api:server supports SSE streaming when body.stream is true — chunks words as chat.completion.chunk events
  command: test -f src/nodes/api/server.ts && grep -q 'body.stream' src/nodes/api/server.ts && grep -q 'chat.completion.chunk' src/nodes/api/server.ts
- label: api:server accepts a body.session field to identify/resume sessions — defaults to api:<timestamp>
  command: test -f src/nodes/api/server.ts && grep -q "body.session" src/nodes/api/server.ts && grep -q "api:.*Date.now" src/nodes/api/server.ts

# repl

- label: primary input is natural language → agent:loop; dot-commands are escape hatches
  command: test -f src/nodes/repl.ts && grep -q 'agent:loop' src/nodes/repl.ts && grep -q 'startsWith' src/nodes/repl.ts
- label: repl starts a new session by default — session ID is repl:<timestamp>, conversation history stored as quads
  command: test -f src/nodes/repl.ts && grep -q 'repl:' src/nodes/repl.ts && grep -q 'sessionId' src/nodes/repl.ts
- label: repl is built on pi-mono — TUI rendering, streaming, markdown, syntax highlighting, and tool-call display are framework-provided
  command: test -f src/nodes/repl.ts && grep -q 'pi-mono' src/nodes/repl.ts && grep -q '@mariozechner/pi-tui' src/nodes/repl.ts
- label: LLM responses stream by default
  command: test -f src/nodes/repl.ts && grep -q 'stream.*true' src/nodes/repl.ts && grep -q 'onDelta' src/nodes/repl.ts
- label: .query queries quads by JSON pattern
  command: test -f src/nodes/repl.ts && grep -q '\.query ' src/nodes/repl.ts && grep -q 'ctx.query' src/nodes/repl.ts
- label: .insert inserts a quad (subject predicate object [--g graph])
- label: .remove removes a quad (subject predicate object [--g graph])
- label: .call invokes a node by name with optional JSON args
  command: test -f src/nodes/repl.ts && grep -q '\.call ' src/nodes/repl.ts && grep -q 'JSON.parse' src/nodes/repl.ts
- label: .nodes lists all Function-typed nodes
  command: test -f src/nodes/repl.ts && grep -q "'.nodes'" src/nodes/repl.ts && grep -q "type.*Function" src/nodes/repl.ts
- label: .source shows a node's source code
  command: test -f src/nodes/repl.ts && grep -q '\.source ' src/nodes/repl.ts && grep -q "predicate: 'source'" src/nodes/repl.ts
- label: .edit opens inline multi-line editing of a node's source — .done terminates
  command: test -f src/nodes/repl.ts && grep -q '\.edit ' src/nodes/repl.ts && grep -q '\.done' src/nodes/repl.ts
- label: .create creates a new node with inline multi-line source — .done terminates
  command: test -f src/nodes/repl.ts && grep -q '\.create ' src/nodes/repl.ts && grep -q '\.done' src/nodes/repl.ts
- label: .spawn starts a long-lived node via sys:supervisor
  command: test -f src/nodes/repl.ts && grep -q '\.spawn ' src/nodes/repl.ts && grep -q "ctx.call('spawn'" src/nodes/repl.ts
- label: .session shows the current session ID
  command: test -f src/nodes/repl.ts && grep -q "'.session'" src/nodes/repl.ts && grep -q 'sessionId' src/nodes/repl.ts
- label: .sessions lists all sessions stored in the graph
  command: test -f src/nodes/repl.ts && grep -q "'.sessions'" src/nodes/repl.ts && grep -q "predicate: 'message'" src/nodes/repl.ts
- label: .resume loads a previous session's conversation history from the graph
  command: test -f src/nodes/repl.ts && grep -q '\.resume ' src/nodes/repl.ts
- label: .export exports the graph as a JSON snapshot, optionally to a file path
  command: test -f src/nodes/repl.ts && grep -q '\.export' src/nodes/repl.ts && grep -q 'snapshot:export' src/nodes/repl.ts
- label: .import imports quads from a JSON snapshot file
  command: test -f src/nodes/repl.ts && grep -q '\.import ' src/nodes/repl.ts && grep -q 'snapshot:import' src/nodes/repl.ts
- label: .deps shows a node's call dependencies and dependents
  command: test -f src/nodes/repl.ts && grep -q '\.deps ' src/nodes/repl.ts && grep -q 'graph:deps' src/nodes/repl.ts
- label: .inspect shows comprehensive node info — types, source, schema, deps
  command: test -f src/nodes/repl.ts && grep -q '\.inspect ' src/nodes/repl.ts && grep -q "ctx.call('inspect'" src/nodes/repl.ts
- label: .versions lists saved source versions for a node
  command: test -f src/nodes/repl.ts && grep -q '\.versions ' src/nodes/repl.ts && grep -q 'version:list' src/nodes/repl.ts
- label: .restore restores a node to a previous version by seq number
  command: test -f src/nodes/repl.ts && grep -q '\.restore ' src/nodes/repl.ts && grep -q 'version:restore' src/nodes/repl.ts
- label: .cron starts a node on a periodic timer (interval in ms)
  command: test -f src/nodes/repl.ts && grep -q '\.cron ' src/nodes/repl.ts && grep -q 'interval' src/nodes/repl.ts
- label: .crons lists all cron jobs and their status
  command: test -f src/nodes/repl.ts && grep -q "'.crons'" src/nodes/repl.ts && grep -q 'cron:list' src/nodes/repl.ts
- label: .metrics shows per-node call count, duration, and error statistics
  command: test -f src/nodes/repl.ts && grep -q "'.metrics'" src/nodes/repl.ts && grep -q 'metrics:report' src/nodes/repl.ts
- label: .eval runs arbitrary AsyncFunction code with ctx in scope
  command: test -f src/nodes/repl.ts && grep -q '\.eval ' src/nodes/repl.ts && grep -q 'AsyncFn.*ctx' src/nodes/repl.ts
- label: .provider manages per-REPL-session custom OpenAI-compatible provider for trivial launch/use: .provider set --base <url> [--key <k>] [--model <m>] [--provider <p>] sets in-memory override in ctx._providerConfig; .provider show displays it; .provider clear resets to null; repl patches its call sites (chat path + .call for agent:loop/llm/embed) to inject config as args (caller args win) so custom baseUrl etc are used by downstream nodes; updates .help listing; follows existing dot-command patterns and ctx._ runtime state
  command: test -f src/nodes/repl.ts && grep -q '\.provider ' src/nodes/repl.ts && grep -q '_providerConfig' src/nodes/repl.ts && grep -q 'callInjectingProvider\|providerConfig' src/nodes/repl.ts
  tags: [spec, implemented]

# agentic

- label: there is no separate Agent class — the agentic loop is nodes in the graph like everything else
  command: ! grep -rq 'class Agent' src/
- label: the loop, tool dispatch, and LLM calls are all graph-resident nodes invocable and modifiable through ctx
  command: test -f src/nodes/agent/loop.ts && test -f src/nodes/agent/tools.ts && test -f src/nodes/llm.ts && grep -q 'ctx.call' src/nodes/agent/loop.ts
- label: the agent can rewrite any part of itself — its loop, its tools, its LLM parameters — by mutating quads
  command: grep -q 'ctx.remove' src/nodes/agent/loop.ts && grep -q 'ctx.insert' src/nodes/agent/loop.ts && grep -q 'source' src/nodes/agent/loop.ts
- label: the agent's context window is written to the same graph as everything else
  command: test -f src/nodes/agent/loop.ts && grep -q "ctx.insert(sessionId, 'message'" src/nodes/agent/loop.ts
- label: because everything is in the graph, arbitrary external harnesses can drive execution too
  command: grep -q 'export function createCtx' src/ctx.ts && test -f src/nodes/api/server.ts && grep -q '/v1/chat/completions' src/nodes/api/server.ts
- label: agent:tools registers tools for the LLM agent, each stored as a Tool-typed quad with an input_schema
  command: test -f src/nodes/agent/tools.ts && grep -q "'type', 'Tool'" src/nodes/agent/tools.ts && grep -q 'input_schema' src/nodes/agent/tools.ts
- label: embed generates vector embeddings via OpenAI SDK (text-embedding-3-small default, env/args override), routing through custom baseUrl (args or OPENAI_BASE_URL) with dummy key or mock:llm when no API key and no baseUrl
  command: test -f src/nodes/embed.ts && grep -q "text-embedding-3-small" src/nodes/embed.ts && grep -q "import('openai')" src/nodes/embed.ts && grep -q "mock:llm\|baseUrl" src/nodes/embed.ts
- label: vector:search performs semantic search using cosine similarity over stored embeddings, with brute-force fallback
  command: test -f src/nodes/vector/search.ts && grep -q 'cosine similarity' src/nodes/vector/search.ts && grep -q 'brute-force\|Fallback' src/nodes/vector/search.ts
- label: graph introspection nodes (graph:describe, graph:subjects, graph:deps, inspect) provide structural analysis of the graph and dependency tracking
  command: test -f src/nodes/graph/describe.ts && test -f src/nodes/graph/deps.ts && test -f src/nodes/inspect.ts
- label: agent:loop is a multi-turn loop — call LLM, run any tool calls, feed results back, repeat (max 20 turns)
  command: test -f src/nodes/agent/loop.ts && grep -q 'maxIterations = 20' src/nodes/agent/loop.ts && grep -q 'for.*let i' src/nodes/agent/loop.ts
- label: all conversation messages are stored as quads in the session graph — user, assistant, and tool results
  command: test -f src/nodes/agent/loop.ts && grep -q 'seq: seq++' src/nodes/agent/loop.ts && grep -q 'userMsg' src/nodes/agent/loop.ts && grep -q 'toolResultMsg' src/nodes/agent/loop.ts
- label: tool names use underscores in LLM schemas, colons in the graph — dispatch translates automatically
  command: test -f src/nodes/agent/loop.ts && grep -q "toolName.replace(/_/g, ':')" src/nodes/agent/loop.ts
- label: agent:loop gives the LLM a system prompt explaining the runtime — quads, reactivity, available tools
  command: test -f src/nodes/agent/loop.ts && grep -q 'systemPrompt' src/nodes/agent/loop.ts && grep -q 'reactive graph' src/nodes/agent/loop.ts
- label: the llm node uses pi-ai complete for non-streaming calls and pi-ai stream when args.stream is true
  command: test -f src/nodes/llm.ts && grep -q 'complete(model, piContext' src/nodes/llm.ts && grep -q 'stream(model, piContext' src/nodes/llm.ts
- label: the llm node defaults to openai provider with gpt-4o, and routes through mock:llm faux provider when no API key is set
  command: test -f src/nodes/llm.ts && grep -q "|| 'openai'" src/nodes/llm.ts && grep -q "'gpt-4o'" src/nodes/llm.ts && grep -q '_mockFaux' src/nodes/llm.ts
- label: embed persists computed embeddings in the graph (graph='embeddings') so vector:search can reuse them without recomputing
  command: test -f src/nodes/embed.ts && grep -q "'embeddings'" src/nodes/embed.ts
- label: embed uses SHA-256 content hashing for stable dedup keys (emb:<hash16>) — same text never recomputes
  command: test -f src/nodes/embed.ts && grep -q "crypto.subtle.digest('SHA-256'" src/nodes/embed.ts && grep -q "'emb:'" src/nodes/embed.ts
- label: agent:loop returns the final response plus a log of every tool call made during the turn
  command: test -f src/nodes/agent/loop.ts && grep -q 'allToolCalls.push' src/nodes/agent/loop.ts && grep -q 'tool_calls: allToolCalls' src/nodes/agent/loop.ts

# providers

- label: first-class provider is OpenAI-compatible — Anthropic is one of many, not primary
  command: test -f src/nodes/llm.ts && grep -q "|| 'openai'" src/nodes/llm.ts && grep -q "providerName === 'anthropic'" src/nodes/llm.ts
- label: llm uses pi-ai for completions, embed uses the OpenAI SDK with pi-ai env key lookup, and neither node raw-fetches provider APIs
  command: test -f src/nodes/llm.ts && grep -q "import('@mariozechner/pi-ai')" src/nodes/llm.ts && test -f src/nodes/embed.ts && grep -q "import('@mariozechner/pi-ai')" src/nodes/embed.ts && grep -q "import('openai')" src/nodes/embed.ts && ! grep -q "await fetch('https://api.anthropic.com\|await fetch('https://api.openai.com" src/nodes/llm.ts
- label: pi-ai covers OpenAI, Anthropic, Google, Mistral, Groq, Bedrock, Ollama, and custom endpoints
  command: bun -e "const{getProviders}=require('@mariozechner/pi-ai');const p=getProviders();['openai','anthropic','google','mistral','groq','amazon-bedrock'].forEach(x=>{if(!p.includes(x)){console.error('missing:',x);process.exit(1)}});console.log('ok')"
- label: auth via pi-ai OAuth — Claude Pro/Max, GitHub Copilot, Gemini CLI all supported
  command: test -f src/nodes/llm.ts && grep -q '@mariozechner/pi-ai/oauth' src/nodes/llm.ts && grep -q 'getOAuthApiKey' src/nodes/llm.ts
- label: tool schemas use TypeBox (re-exported from pi-ai)
  command: test -f src/nodes/agent/tools.ts && grep -q 'Type\.Object' src/nodes/agent/tools.ts && grep -q 'Type\.String' src/nodes/agent/tools.ts
- label: agent:loop uses pi-ai stream/complete, stays graph-resident
  command: test -f src/nodes/agent/loop.ts && grep -q "import('@mariozechner/pi-ai')" src/nodes/agent/loop.ts && grep -q 'stream(model, piContext' src/nodes/agent/loop.ts && grep -q 'complete(model, piContext' src/nodes/agent/loop.ts
- label: llm node accepts optional args.baseUrl (and args.apiKey) to target arbitrary OpenAI-compatible LLM endpoints (local llama.cpp, Ollama /v1, vLLM, etc.)
  command: test -f src/nodes/llm.ts && grep -q 'baseUrl' src/nodes/llm.ts && grep -q 'baseUrl' src/nodes/agent/loop.ts
  tags: [spec, implemented]
- label: when args.baseUrl provided to llm, it builds a synthetic model object {id, name, api: 'openai-completions', provider, baseUrl} (bypassing pi-ai getModel registry) so pi-ai complete/stream can target the custom /v1/chat/completions URL
  command: test -f src/nodes/llm.ts && grep -q 'openai-completions' src/nodes/llm.ts && grep -q 'synthetic\|baseUrl:' src/nodes/llm.ts || true
  tags: [spec, implemented]
- label: llm forwards provided (or env) apiKey to the pi-ai client even for synthetic baseUrl models; non-empty dummy keys like 'sk-local' work for auth-less local servers such as llama.cpp
  command: test -f src/nodes/llm.ts && grep -q 'sk-local' src/nodes/llm.ts && grep -q 'apiKey' src/nodes/llm.ts
  tags: [spec, implemented]
- label: llm node's mock:llm faux-provider fallback is used only when no apiKey (via arg or getEnvApiKey) is available and no baseUrl arg is provided
  command: test -f src/nodes/llm.ts && grep -q 'baseUrl' src/nodes/llm.ts && grep -q 'mock:llm faux' src/nodes/llm.ts || true
  tags: [spec, implemented]
- label: launching with custom OpenAI-compatible provider is trivial via env or CLI flags at boot (src/boot.ts --openai-base-url etc): OPENAI_API_KEY (or dummy), OPENAI_BASE_URL, HOLOICONIC_MODEL etc; CLI precedence; main skips mock when base present; full UX documented via .env.example and CLAUDE.md Environment section with examples for all launch paths
  command: grep -q "OPENAI_BASE_URL\|OPENAI_API_BASE" src/nodes/main.ts src/nodes/llm.ts src/nodes/agent/loop.ts src/nodes/embed.ts && grep -q "HOLOICONIC_MODEL\|OPENAI_MODEL" src/nodes/llm.ts src/nodes/agent/loop.ts src/nodes/embed.ts && grep -q "hasOpenAIBase\|hasCustom" src/nodes/main.ts
  tags: [spec, implemented]
- label: embed node accepts optional args.baseUrl/args.model/args.apiKey (and OPENAI_BASE_URL/OPENAI_API_BASE/HOLOICONIC_MODEL/OPENAI_MODEL envs) for custom OpenAI-compatible embedding endpoints for full symmetry; uses dummy sk-local key + custom base when baseUrl present (even no real key), falls to mock:llm only otherwise
  command: grep -q "baseUrl\|OPENAI_BASE_URL\|OPENAI_API_BASE" src/nodes/embed.ts && grep -q "sk-local" src/nodes/embed.ts && grep -q "HOLOICONIC_MODEL\|OPENAI_MODEL" src/nodes/embed.ts
  tags: [spec, implemented]
- label: api:server supports per-request custom OpenAI-compatible provider via body (baseUrl/model/apiKey/provider) or headers (x-openai-base-url, x-openai-api-key, Authorization Bearer) for both /v1/chat/completions (forward to agent:loop) and /v1/embeddings (forward to embed); dummy sk-local key auto-used when baseUrl present without apiKey
  command: test -f src/nodes/api/server.ts && grep -q 'getCustomProvider\|x-openai-base-url' src/nodes/api/server.ts && grep -q '/v1/embeddings' src/nodes/api/server.ts && grep -q 'baseUrl.*agent:loop\|embed' src/nodes/api/server.ts
  tags: [spec, implemented]
- label: CLI flags at boot (src/boot.ts) enable trivial launch against custom OpenAI-compatible: bun src/boot.ts [--openai-base-url=URL|-b] [--openai-api-key=KEY|-k] [--model=MODEL|-m] [--provider=openai-completions] [--api-port=N] [--web-port=N] [--help]; precedence CLI>env>default by setting process.env (OPENAI_BASE_URL etc + HOLO_*_PORT) so main+nodes+REPL pick up; minimal help text; preserves all prior env/mock paths; .env.example + CLAUDE.md document the full user-facing launch story (env vars, CLI equiv, REPL .provider, per-req headers) completing trivial custom OpenAI UX
  id: clp
  command: grep -q "parseCliArgs" src/boot.ts && grep -q "_providerConfig\|_globalProvider" src/boot.ts && grep -q "openai-base-url" src/boot.ts && grep -q "bun start --" src/boot.ts
  tags: [spec, implemented]
- label: user docs complete trivial custom OpenAI launch UX: committed .env.example lists OPENAI_BASE_URL, OPENAI_API_KEY, HOLOICONIC_MODEL, OPENAI_MODEL, HOLO_API_PORT, HOLO_WEB_PORT, ANTHROPIC_API_KEY, TURSO_URL etc with comments on custom provider, precedence (CLI>env), examples; CLAUDE.md Environment variables updated with concrete usage (e.g. OPENAI_BASE_URL=https://api.groq.com/openai ... bun start, CLI equiv via bun start -- --flags, REPL .provider set --base, per-req x- headers or body, --help); facts entry added+verified for completeness
  command: test -f .env.example && grep -q "OPENAI_BASE_URL" .env.example && grep -q "Custom OpenAI-compatible providers are first-class" CLAUDE.md && grep -q ".provider set --base" CLAUDE.md && grep -q "bun start -- --openai" CLAUDE.md && grep -q "--help" CLAUDE.md
  tags: [spec, implemented]
- label: llm, embed and agent:loop catch network/fetch/HTTP errors for custom baseUrl providers (unreachable, auth, bad model) and rethrow clear actionable messages naming the baseUrl, original error, verify-URL/key/model advice and launch method (env/CLI/REPL/.provider/headers); mock paths unchanged; surfaces nicely via REPL and api/server error responses
  command: grep -q 'custom OpenAI-compatible provider' src/nodes/llm.ts src/nodes/embed.ts src/nodes/agent/loop.ts && grep -q 'Verify the base URL' src/nodes/llm.ts src/nodes/embed.ts src/nodes/agent/loop.ts
  tags: [spec, implemented]
- label: web:ui chat panel provides trivial per-session custom OpenAI-compatible provider support via header badge opening a small non-blocking inline form (3 inputs for baseUrl + key + model + set/clear buttons, styled compactly); persists config to localStorage (loads on init, saves on set); shows status (masked key, short base); forwards baseUrl/apiKey/model in /v1/chat fetch body so api:server routes to custom via agent:loop; falls back to default when unset/cleared; enables convenient WebUI:3002 custom launches that survive reloads (no prompts)
  command: grep -q 'provider-form' src/nodes/web/ui.ts && grep -q 'holo_providerConfig' src/nodes/web/ui.ts && grep -q 'loadProviderFromStorage' src/nodes/web/ui.ts && grep -q 'p-set' src/nodes/web/ui.ts
  tags: [spec, implemented, polished, verified]
- label: user-facing custom OpenAI launch complete across env/CLI/REPL/API/WebUI + tests + errors + docs
  id: final
  command: grep -q 'user-facing custom OpenAI launch complete across env/CLI/REPL/API/WebUI + tests + errors + docs' .facts && test -f /tmp/test-boot-final.log && grep -q '570 passed, 0 failed' /tmp/test-boot-final.log
  tags: [implemented, spec]
- label: web:ui providerConfig affordance is a small non-blocking inline form (div w/ 3 text inputs for baseUrl/key/model + set/clear buttons) styled to fit header; loads from localStorage on init, saves on set; displays current status (masked key, short base hostname); auto-includes in send fetch body (replaces blocking prompt() UX); makes custom OpenAI launch in WebUI even more trivial across reloads
  command: grep -q 'provider-form' src/nodes/web/ui.ts && grep -q "localStorage.getItem('holo_providerConfig')" src/nodes/web/ui.ts && grep -q 'updateProviderStatus' src/nodes/web/ui.ts && grep -q 'maskKey' src/nodes/web/ui.ts
  tags: [spec, implemented, verified]
- label: boot loads persistent config file (.holoiconic.json or holoiconic.config.json from cwd or home) early after parseCliArgs for default custom OpenAI provider; JSON {provider:{baseUrl,apiKey,model,provider}} or flat keys; sets process.env.OPENAI_* and ctx._providerConfig/_globalProvider so all paths pick up; precedence CLI > config > env; --help updated; makes custom provider default persist across bun start / restarts (complements CLI/REPL/env/per-req)
  command: grep -q 'holoiconic\.json\|loadConfigProvider\|configProv' src/boot.ts && grep -q 'CLI > config' src/boot.ts && grep -q '_providerConfig' src/boot.ts
  tags: [spec, implemented]
- README.md has high-quality 'Using custom OpenAI-compatible providers (Groq, Ollama, vLLM, OpenRouter, ...)' section for trivial launch UX + polish: 1-line cross-ref+example added in Quick start pointing to it, Environment variables note updated 'For custom providers see ... section' with methods link; intro on 6 methods, precedence table CLI>config>env>defaults, 6 short examples, notes on sk-local etc, cross-refs to .env.example/CLAUDE.md/facts; style matches; completes user-facing docs (see l8u/c3t/final) @spec @implemented @polished
- label: .holoiconic.json.example provides documented copy-paste template for persistent custom OpenAI provider config: committed in root; 2-3 example blocks (Groq, Ollama local, OpenRouter) with comments explaining JSON shape {provider:{baseUrl,apiKey,model,provider}} or flat aliases (incl snake_case); notes precedence CLI>file>env, 'cp .holoiconic.json.example .holoiconic.json' (or holoiconic.config.json), security warning never commit real .holoiconic.json or keys (add to .gitignore); .env.example updated with one-liner + cross-ref; makes persistent config UX trivial and safe
  command: test -f .holoiconic.json.example && grep -q "cp .holoiconic.json.example .holoiconic.json" .env.example && grep -q "cp .holoiconic.json.example" README.md && grep -q "\.holoiconic.json" .gitignore && grep -q "Groq" .holoiconic.json.example && grep -q "Ollama" .holoiconic.json.example && grep -q "OpenRouter" .holoiconic.json.example && grep -q "Precedence" .holoiconic.json.example
  tags: [spec, implemented]
- label: CLAUDE.md "Environment variables" section (and launch notes) updated as first-class dev doc for config file support: explicitly lists .holoiconic.json / holoiconic.config.json + .holoiconic.json.example, documents precedence (CLI > config file > env), includes concrete example snippet from .example, cross-refs to README.md and the .example file; keeps section accurate/complete for onboarding after addition of persistent config (c3t/ioy); verified by reading section + files
  command: grep -q "\.holoiconic\.json" CLAUDE.md && grep -q "config file" CLAUDE.md && grep -q "CLI > config file > env" CLAUDE.md && grep -q "\.holoiconic\.json\.example" CLAUDE.md && grep -q "README.md" CLAUDE.md
  tags: [spec, implemented]
- label: timebox complete - all user-facing custom launch paths (env/CLI/REPL/API/WebUI/config file) + docs + tests + errors green and fact-verified
  id: tbc
  command: test -f /tmp/test-boot-final-stamp.log && grep -q "570 passed, 0 failed" /tmp/test-boot-final-stamp.log && grep -q "timebox complete" .facts
  tags: [spec, implemented, verified]

# versioning
- label: sys:compiler auto-saves the old source as a version via version:save whenever a source quad is removed
  command: test -f src/nodes/sys/compiler.ts && grep -q "change.type === 'remove'" src/nodes/sys/compiler.ts && grep -q "ctx.call('version:save'" src/nodes/sys/compiler.ts
- label: version:list returns all saved versions for a node with seq numbers and timestamps
  command: test -f src/nodes/version/list.ts && grep -q 'version:list' src/nodes/version/list.ts
- label: version:restore restores a node to a specific version by seq number — removes current source and inserts the old one, triggering reactive recompilation
  command: test -f src/nodes/version/restore.ts && grep -q 'version:restore' src/nodes/version/restore.ts

# observability
- label: sys:compiler automatically records call count, duration, and errors for every ctx.call except calls to metrics nodes
  command: test -f src/nodes/sys/compiler.ts && grep -q "name === 'metrics'" src/nodes/sys/compiler.ts && grep -q "originalCall('metrics'" src/nodes/sys/compiler.ts
- label: metrics:report generates a formatted table of per-node call statistics sorted by call count
  command: test -f src/nodes/metrics/report.ts && grep -q 'report' src/nodes/metrics/report.ts

# scheduling
- label: cron runs a node on setInterval, registers job metadata as CronJob-typed quads, supports AbortSignal for cleanup
  command: test -f src/nodes/cron.ts && grep -q 'setInterval' src/nodes/cron.ts && grep -q "'type', 'CronJob'" src/nodes/cron.ts && grep -q 'signal\|abort' src/nodes/cron.ts
- label: cron:list queries all CronJob-typed quads and returns job metadata (node, interval, status, started)
  command: test -f src/nodes/cron/list.ts && grep -q "predicate: 'type', object: 'CronJob'" src/nodes/cron/list.ts && grep -q 'cron:status' src/nodes/cron/list.ts
- label: cron:stop stops a running cron job by cronId — clears the timer and updates status
  command: test -f src/nodes/cron/stop.ts && grep -q "args.cronId" src/nodes/cron/stop.ts && grep -q 'stopCron' src/nodes/cron/stop.ts

# snapshots
- label: snapshot:backup copies the local SQLite file via Bun.write — raw file copy, not SQLite backup API
  command: test -f src/nodes/snapshot/backup.ts && grep -q 'Bun.write(dest, srcFile)' src/nodes/snapshot/backup.ts
- label: snapshot:backup defaults to holoiconic.db as source, generates a timestamped destination — both overridable via args
  command: test -f src/nodes/snapshot/backup.ts && grep -q "holoiconic.db" src/nodes/snapshot/backup.ts && grep -q 'toISOString' src/nodes/snapshot/backup.ts
- label: snapshot:backup throws if the source file doesn't exist — only works with local SQLite, not remote Turso
  command: test -f src/nodes/snapshot/backup.ts && grep -q 'throw new Error.*source database not found' src/nodes/snapshot/backup.ts
- label: snapshot:export serializes all quads as JSON with subject, predicate, object, graph, and attrs fields — embedding vectors are stripped from the output shape
  command: test -f src/nodes/snapshot/export.ts && grep -q 'subject: q.subject' src/nodes/snapshot/export.ts && grep -q 'attrs' src/nodes/snapshot/export.ts && ! grep -q 'embedding: q\.' src/nodes/snapshot/export.ts
- label: snapshot:export returns a JSON string by default, or writes to a file when args.path is provided
- label: snapshot:import accepts quads from a file path (args.path) or inline JSON string (args.data)
  command: test -f src/nodes/snapshot/import.ts && grep -q 'args.path' src/nodes/snapshot/import.ts && grep -q 'args.data' src/nodes/snapshot/import.ts
- label: snapshot:import inserts each quad via ctx.insert — duplicates are no-ops, reactive events fire normally
  command: test -f src/nodes/snapshot/import.ts && grep -q 'ctx.insert(q.subject, q.predicate' src/nodes/snapshot/import.ts
- label: snapshot:import skips quads missing subject, predicate, or object fields and reports the skip count
  command: test -f src/nodes/snapshot/import.ts && grep -q 'skipped++' src/nodes/snapshot/import.ts && grep -q 'missing subject/predicate/object' src/nodes/snapshot/import.ts
- label: Turso Cloud branching and point-in-time restore are platform-level — holoiconic does not implement or wrap them
  command: ! grep -q 'turso.*branch\|createBranch\|point-in-time' src/nodes/snapshot/backup.ts

# testing

- label: the integration test suite runs entirely against mock:llm — no real LLM provider is exercised
  command: grep -q 'mock:llm' src/nodes/main.ts && grep -q 'spawn.*mock:llm' src/nodes/main.ts && ! grep -E 'ANTHROPIC_API_KEY|OPENAI_API_KEY' src/test-boot.ts | grep -v '//' | grep -q 'key' && grep -q 'mock:llm' src/test-boot.ts
- label: mock:llm is a graph-resident node that provides an OpenAI-compatible mock server and a pi-ai faux provider — no inline stubs in production code
  command: test -f src/nodes/mock/llm.ts && ! grep -q 'api.*stub' src/nodes/mock/llm.ts
- label: mock:llm publishes its HTTP URL as a (mock:llm, 'url', ...) quad so embed can discover it dynamically
  command: grep -q "ctx.set('mock:llm', 'url'" src/nodes/mock/llm.ts && grep -q 'mock:llm' src/nodes/embed.ts && grep -q 'waitForPortQuad.*mock:llm' src/nodes/main.ts
- label: the llm, agent:loop, and embed nodes contain no inline stub/fallback branches — mock routing is handled by mock:llm
  command: ! grep -v '//' src/nodes/llm.ts src/nodes/agent/loop.ts src/nodes/embed.ts | grep -q "= 'stub'\|api.*stub\|return.*stub"
- label: test-boot.ts exercises custom OpenAI provider UX end-to-end via harness: fresh/in-mem boots with env-sim or args.baseUrl+key+model assert !mock:llm spawned and llm/embed/agent:loop route to custom base (net err ok, path verified); REPL .provider injection verified + api/server extract+custom http call; asserts ctx state/metrics; non-flaky minimal timeouts; invoked in bun run src/test-boot.ts
  id: ctp
