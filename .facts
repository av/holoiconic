## mock
- label: mock:llm stops its Bun HTTP server when its AbortSignal is aborted so the process can exit cleanly
  command: bun -e 'const {createDatabase,initSchema}=await import("./src/db.ts");const{createCtx}=await import("./src/ctx.ts");const{seedTemplate}=await import("./src/template.ts");const db=createDatabase(":memory:");await initSchema(db);const ctx=createCtx(db);await seedTemplate(ctx);await ctx.call("sys:compiler");const ac=new AbortController();const run=ctx.call("mock:llm",{signal:ac.signal});await new Promise(r=>setTimeout(r,50));const url=(await ctx.query({subject:"mock:llm",predicate:"url"}))[0]?.object;if(!url)process.exit(1);const before=await fetch(url+"/health");if(before.status!==200)process.exit(1);ac.abort();await Promise.race([run,new Promise((_,rej)=>setTimeout(()=>rej(new Error("timeout")),1000))]);let stopped=false;try{const timeout=new AbortController();const timer=setTimeout(()=>timeout.abort(),300);const after=await fetch(url+"/health",{signal:timeout.signal});clearTimeout(timer);stopped=!after.ok}catch{stopped=true}if(!stopped)process.exit(1);'
  tags: [implemented]

